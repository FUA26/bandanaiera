generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  category        String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String     @default(cuid())
  permissionId String     @default(cuid())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Role {
  id                       String           @id @default(cuid())
  name                     String           @unique
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  permissions              RolePermission[]
  defaultForSystemSettings SystemSettings[] @relation("DefaultUserRole")
  users                    User[]
}

model User {
  id                   String           @id @default(cuid())
  name                 String?
  email                String           @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  roleId               String
  bio                  String?
  passwordResetToken   String?          @unique
  passwordResetExpires DateTime?
  accounts             Account[]
  permissionCache      PermissionCache?
  sessions             Session[]
  role                 Role             @relation(fields: [roleId], references: [id])

  // Avatar: Denormalized approach
  avatarId      String? @unique
  avatar        File?   @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  avatarUrl     String? // Cache URL from File.cdnUrl
  uploadedFiles File[]

  // Service Management Relations
  createdServices Service[]            @relation("ServiceCreator")
  updatedServices Service[]            @relation("ServiceUpdater")
  activityLogs    ServiceActivityLog[]
}

model PermissionCache {
  id          String   @id @default(cuid())
  userId      String   @unique
  updatedAt   DateTime @updatedAt
  permissions String[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemSettings {
  id                           String   @id @default(cuid())
  allowRegistration            Boolean  @default(true)
  requireEmailVerification     Boolean  @default(true)
  defaultUserRoleId            String
  emailVerificationExpiryHours Int      @default(24)
  siteName                     String   @default("Naiera")
  siteDescription              String?
  minPasswordLength            Int      @default(8)
  requireStrongPassword        Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  defaultUserRole              Role     @relation("DefaultUserRole", fields: [defaultUserRoleId], references: [id])
}

model File {
  id               String       @id @default(cuid())
  originalFilename String
  storedFilename   String       @unique
  mimeType         String
  size             Int
  category         FileCategory @default(OTHER)

  // Storage
  bucketName  String  @default("naiera-uploads")
  storagePath String // e.g., "users/123/avatar/abc123.jpg"
  cdnUrl      String?

  // Ownership
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  // Usage & Lifecycle
  isPublic       Boolean   @default(false)
  referenceCount Int       @default(0)
  lastAccessedAt DateTime  @default(now())
  expiresAt      DateTime? // Auto-delete untuk temporary files
  deletedAt      DateTime? // Soft delete

  // Metadata
  width  Int? // Untuk images
  height Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  avatars            User[]    @relation("UserAvatar")
  featuredInServices Service?  @relation("ServiceFeaturedImage")
  attachedToServices Service[] @relation("ServiceAttachments")

  @@index([uploadedById])
  @@index([category])
  @@index([expiresAt])
  @@index([deletedAt])
}

enum FileCategory {
  AVATAR
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  ARCHIVE
  OTHER
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ServiceCategory {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  icon         String? // Icon name or emoji
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  services Service[]

  @@index([isActive])
  @@index([displayOrder])
}

model Service {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  content     String?       @db.Text
  status      ServiceStatus @default(DRAFT)

  // Categorization
  categoryId String
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Metadata
  featuredImageId  String? @unique
  featuredImage    File?   @relation("ServiceFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  featuredImageUrl String? // Cache URL from File.cdnUrl
  attachments      File[]  @relation("ServiceAttachments")

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  // Display settings
  isFeatured     Boolean @default(false)
  displayOrder   Int     @default(0)
  showOnHomepage Boolean @default(false)

  // Audit
  createdById String
  createdBy   User      @relation("ServiceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User      @relation("ServiceUpdater", fields: [updatedById], references: [id], onDelete: Restrict)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  activityLogs ServiceActivityLog[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([isFeatured])
  @@index([displayOrder])
  @@index([createdById])
  @@index([updatedById])
}

model ServiceActivityLog {
  id        String  @id @default(cuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Change details
  action  String // CREATED, UPDATED, DELETED, PUBLISHED, ARCHIVED, etc.
  changes Json? // Store the changes made (for UPDATE actions)
  reason  String? // Optional reason for the change

  // Audit
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([serviceId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
